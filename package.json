{
  "name": "mcp-readonly-server",
  "version": "1.0.0",
  "private": true,
  "description": "Generic read-only MCP server (Streamable HTTP). Resolves a Bearer token to a per-org Postgres role and proxies SELECTs. All security lives in the database.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "provision": "tsx scripts/provision-token.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
