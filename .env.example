# Local development env. In Swarm these come from Docker secrets (see stack.yaml).
# Copy to .env and fill in. NEVER commit .env.

PORT=3000

# Supabase project ref. Host becomes db.<ref>.supabase.co.
PROJECT_REF=YOUR_PROJECT_REF

# 32-byte AES master key as 64 hex chars. Generate: openssl rand -hex 32
# Must match the key used by scripts/provision-token.ts.
MCP_MASTER_KEY=

# Control connection for the mcp_resolver role (reads only internal.mcp_api_tokens).
MCP_RESOLVER_CONN=postgresql://mcp_resolver:SENHA@db.YOUR_PROJECT_REF.supabase.co:6543/postgres?sslmode=require

# Defense-in-depth statement guard (true|false). Default true.
MCP_STATEMENT_GUARD=true

# Resolver cache TTL in ms (also the max revocation delay). Default 60000.
MCP_CACHE_TTL_MS=60000
